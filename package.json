{
  "name": "crashtown_game",
  "version": "1.0.0",
  "private": true,
  "description": "Mirror fidèle du jeu web Crashtown (HTML/CSS/JS/Assets)",
  "scripts": {
    "serve": "python3 -m http.server 5173",
    "radio:scan": "node scripts/generate-radio-playlists.mjs",
    "radio:scan:strict": "node scripts/generate-radio-playlists.mjs --strict",
    "radio:scan:strict:full": "node scripts/generate-radio-playlists.mjs --strict --fail-on-empty",
    "vehicle:scan": "node scripts/generate-vehicle-catalog.mjs",
    "vehicle:scan:strict": "node scripts/generate-vehicle-catalog.mjs --strict",
    "assets:validate": "npm run vehicle:scan:strict && npm run radio:scan:strict",
    "assets:validate:full": "npm run vehicle:scan:strict && npm run radio:scan:strict:full"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0"
  }
}
